# Application
APP_NAME=CompaniesHouse Tax Stride
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/companiestaxstride
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/companiestaxstride

# Redis (for Celery background tasks)
REDIS_URL=redis://localhost:6379/0

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Companies House API
# Get from: https://developer.company-information.service.gov.uk
COMPANIES_HOUSE_API_KEY=your-companies-house-api-key
COMPANIES_HOUSE_BASE_URL=https://api.company-information.service.gov.uk

# HMRC MTD (Making Tax Digital)
# Get from: https://developer.service.hmrc.gov.uk
HMRC_CLIENT_ID=your-hmrc-client-id
HMRC_CLIENT_SECRET=your-hmrc-client-secret
HMRC_BASE_URL=https://api.service.hmrc.gov.uk
HMRC_SANDBOX_URL=https://test-api.service.hmrc.gov.uk
HMRC_REDIRECT_URI=http://localhost:8000/api/v1/auth/hmrc/callback
HMRC_SANDBOX=true

# Stripe
# Get from: https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Submission Prices (in pence GBP)
PRICE_CONFIRMATION_STATEMENT=1499
PRICE_ANNUAL_ACCOUNTS=2499
PRICE_VAT_RETURN=999
PRICE_CT600=3499

# PayPal
# Get from: https://developer.paypal.com
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox

# Shopify
# Get from: https://partners.shopify.com
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
SHOPIFY_SCOPES=read_orders,read_products,read_customers,read_finances
SHOPIFY_REDIRECT_URI=http://localhost:8000/api/v1/integrations/shopify/callback

# Email (SendGrid or SMTP)
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@companiestaxstride.com
FROM_NAME=CompaniesHouse Tax Stride

# Frontend URL
FRONTEND_URL=http://localhost:3000